{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declarationMap": true,
    "baseUrl": ".",
    "types": ["node"],
    "lib": ["ES2020", "DOM"],
    "paths": {
      "@hazeljs/flow": ["../flow/dist/index.d.ts"],
      "@hazeljs/flow/prisma": ["../flow/dist/prisma.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
