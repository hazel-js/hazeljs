{
  "name": "hazeljs-ai-native-app",
  "version": "0.1.0",
  "description": "A HazelJS AI-native application with agents, RAG, and chat",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@hazeljs/core": "latest",
    "@hazeljs/ai": "latest",
    "@hazeljs/agent": "latest",
    "@hazeljs/rag": "latest",
    "@hazeljs/config": "latest",
    "@hazeljs/cache": "latest",
    "@hazeljs/inspector": "latest",
    "@hazeljs/prisma": "latest",
    "@prisma/client": "^5.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "prisma": "^5.0.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "author": "",
  "license": "Apache-2.0"
}
