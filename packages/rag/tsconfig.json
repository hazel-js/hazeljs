{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@hazeljs/prompts": ["../prompts/src"],
      "@hazeljs/memory": ["../memory/src/index.ts"],
      "@hazeljs/memory/prisma": ["../memory/src/prisma.ts"]
    },
    "types": [
      "jest",
      "node"
    ]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../ai"
    },
    {
      "path": "../prompts"
    },
    {
      "path": "../memory"
    }
  ]
}
