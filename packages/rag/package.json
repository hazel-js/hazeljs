{
  "name": "@hazeljs/rag",
  "version": "0.2.4",
  "description": "Retrieval-Augmented Generation (RAG) and vector search for HazelJS framework",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./memory-hazel": {
      "types": "./dist/memory-hazel.d.ts",
      "default": "./dist/memory-hazel.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --skipLibCheck",
    "test": "jest --coverage --passWithNoTests",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hazeljs/prompts": "file:../prompts",
    "reflect-metadata": "^0.2.1"
  },
  "peerDependencies": {
    "@pinecone-database/pinecone": "^3.0.0",
    "weaviate-ts-client": "^2.0.0",
    "@qdrant/js-client-rest": "^1.9.0",
    "chromadb": "^1.8.0",
    "openai": "^4.0.0",
    "cohere-ai": "^7.0.0",
    "@huggingface/inference": "^2.0.0",
    "@hazeljs/ai": ">=0.2.0-beta.0",
    "@hazeljs/core": ">=0.2.0-beta.0",
    "pdf-parse": "^1.1.1",
    "mammoth": "^1.11.0",
    "cheerio": "^1.0.0",
    "@hazeljs/memory": ">=0.2.0-beta.0"
  },
  "peerDependenciesMeta": {
    "@pinecone-database/pinecone": {
      "optional": true
    },
    "weaviate-ts-client": {
      "optional": true
    },
    "@qdrant/js-client-rest": {
      "optional": true
    },
    "chromadb": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "cohere-ai": {
      "optional": true
    },
    "@huggingface/inference": {
      "optional": true
    },
    "pdf-parse": {
      "optional": true
    },
    "mammoth": {
      "optional": true
    },
    "cheerio": {
      "optional": true
    },
    "@hazeljs/memory": {
      "optional": true
    }
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/src/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@hazeljs/prompts$": "<rootDir>/../prompts/src/index.ts",
      "^@hazeljs/memory$": "<rootDir>/../memory/src/index.ts",
      "^@hazeljs/memory/prisma$": "<rootDir>/../memory/src/prisma.ts"
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/index.ts",
      "!src/rag.module.ts",
      "!src/rag.service.ts",
      "!src/rag-pipeline-with-memory.ts",
      "!src/vector-stores/**",
      "!src/embeddings/**",
      "!src/agentic/**",
      "!src/decorators/**",
      "!src/memory/**",
      "!src/loaders/pdf.loader.ts",
      "!src/loaders/docx.loader.ts",
      "!src/loaders/web.loader.ts",
      "!src/loaders/github.loader.ts",
      "!src/loaders/youtube-transcript.loader.ts",
      "!src/loaders/index.ts",
      "!src/graph/index.ts",
      "!src/prompts/**",
      "!src/types/**"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 85,
        "branches": 75,
        "functions": 85,
        "lines": 85
      }
    }
  },
  "devDependencies": {
    "@hazeljs/memory": "file:../memory",
    "openai": "^4.0.0",
    "@types/node": "^20.17.50",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hazeljs/hazeljs.git",
    "directory": "packages/rag"
  },
  "keywords": [
    "hazeljs",
    "rag",
    "retrieval-augmented-generation",
    "vector-search",
    "embeddings",
    "semantic-search",
    "pinecone",
    "weaviate",
    "qdrant",
    "chromadb",
    "ai",
    "llm"
  ],
  "author": "Muhammad Arslan <muhammad.arslan@hazeljs.ai>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/hazeljs/hazel-js/issues"
  },
  "homepage": "https://hazeljs.ai"
}
