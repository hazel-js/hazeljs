{
  "name": "@hazeljs/mcp-example-agent",
  "version": "1.0.0",
  "description": "Example: expose @hazeljs/agent @Tool()-decorated methods as MCP tools over STDIO",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node --compiler-options '{\"experimentalDecorators\":true,\"emitDecoratorMetadata\":true}' src/main.ts",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@hazeljs/agent": "file:../../../agent",
    "@hazeljs/mcp": "file:../../",
    "reflect-metadata": "^0.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
