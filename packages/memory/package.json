{
  "name": "@hazeljs/memory",
  "version": "0.2.0-rc.8",
  "description": "Pluggable user memory for HazelJS - profile, preferences, behavioral patterns, emotional state, episodic and semantic memory with multi-store support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./prisma": {
      "types": "./dist/prisma.d.ts",
      "default": "./dist/prisma.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "prisma generate && tsc --skipLibCheck && (test -d src/generated && cp -r src/generated dist/ || true)",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "test": "jest --coverage --passWithNoTests",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "optionalDependencies": {
    "@prisma/client": "^6.8.2"
  },
  "devDependencies": {
    "prisma": "^6.8.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.50",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "pg": "^8.0.0",
    "ioredis": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hazeljs/hazeljs",
    "directory": "packages/memory"
  },
  "keywords": [
    "hazeljs",
    "memory",
    "user-memory",
    "preferences",
    "episodic",
    "agent",
    "rag",
    "prisma"
  ],
  "author": "Muhammad Arslan <muhammad.arslan@hazeljs.ai>",
  "license": "Apache-2.0"
}
