{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
      "@hazeljs/core": [
        "../core/src"
      ],
      "@hazeljs/cache": [
        "../cache/src"
      ],
      "@hazeljs/prompts": [
        "../prompts/src"
      ]
    },
    "types": [
      "jest",
      "node"
    ]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/node_modules/openai/src/**"
  ],
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../cache"
    },
    {
      "path": "../prompts"
    }
  ]
}
