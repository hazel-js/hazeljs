{
  "name": "@hazeljs/saga",
  "version": "0.1.0",
  "description": "Saga pattern implementation for HazelJS - Orchestration and Choreography for distributed transactions",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest --coverage --passWithNoTests",
    "test:ci": "jest --coverage --coverageReporters=text --coverageReporters=lcov --coverageReporters=clover --no-coverage-threshold",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hazeljs/core": "file:../core",
    "@hazeljs/event-emitter": "file:../event-emitter",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.50",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^8.56.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Muhammad Arslan <muhammad.arslan@hazeljs.ai>",
  "license": "Apache-2.0"
}
